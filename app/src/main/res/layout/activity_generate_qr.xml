<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🚪 Door Access QR"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:paddingBottom="8dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap below to generate a one-time QR code"
        android:textSize="14sp"
        android:textColor="#555555"
        android:gravity="center"
        android:paddingBottom="20dp"/>

    <!-- QR Code Image -->
    <ImageView
        android:id="@+id/ivQrCode"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:visibility="gone"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:layout_marginBottom="16dp"/>

    <!-- Token preview text -->
    <TextView
        android:id="@+id/tvTokenInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#888888"
        android:visibility="gone"
        android:gravity="center"
        android:paddingBottom="20dp"/>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginBottom="16dp"/>

    <!-- Generate Button -->
    <Button
        android:id="@+id/btnGenerateQR"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Generate New QR Code"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <!-- Share Button — hidden until QR is generated -->
    <Button
        android:id="@+id/btnShareQR"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📤 Share QR Code"
        android:textSize="15sp"
        android:visibility="gone"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"/>

</LinearLayout>
