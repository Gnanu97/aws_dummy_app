<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Title ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IoT Device Onboarding"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"
            android:textColor="#1A1A1A"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scan for nearby ESP32 devices"
            android:textSize="14sp"
            android:gravity="center"
            android:textColor="#666666"
            android:paddingBottom="16dp"/>

        <!-- ── Door Access Section ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DOOR ACCESS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:paddingBottom="6dp"/>

        <Button
            android:id="@+id/btnGenerateQR"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔑 Generate Door Access QR"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnValidateQR"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷 Scan &amp; Validate QR"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"/>

        <!-- ── Auth Section ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AUTH"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:paddingBottom="6dp"/>

        <Button
            android:id="@+id/btnAuthInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔐 View Auth Token Info"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚪 Logout"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"/>

        <!-- ── Device Provisioning Section ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DEVICE PROVISIONING"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:letterSpacing="0.1"
            android:paddingBottom="6dp"/>

        <Button
            android:id="@+id/btnScan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scan for ESP32 Devices"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Press button to start scanning"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="8dp"
            android:textColor="#555555"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Discovered Devices"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:textColor="#333333"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDevices"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:background="#FFFFFF"
            android:elevation="2dp"/>

    </LinearLayout>

</ScrollView>